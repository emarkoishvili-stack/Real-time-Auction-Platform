rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /auctions/{auctionId} {
      // Allow any visitor to view the auction listings
      allow read: if true;
      
      // Allow authenticated users to create or update auctions
      allow write: if request.auth != null;

      // Subcollection of bids
      match /bids/{bidId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
